{# --- Node identity and deterministic peer ordering --- #}
{%- set node_idx = groups['all'].index(inventory_hostname) -%}
{%- set deterministic_peers = peers | unique | sort -%}

{# --- DNS/rule sources and advertised prefixes --- #}
{%- set _rules_file = lookup('file', playbook_dir ~ '/../rules/' ~ ('restricted' if restricted else 'unrestricted') ~ '.json') | from_json -%}
{%- set _rules_ip_cidrs = _rules_file.rules | map(attribute='ip_cidr', default=[]) | flatten -%}
{%- set fakeip_inet4_range = '198.' ~ (18 + node_idx) ~ '.0.0/16' -%}
{%- set fakeip_inet6_range = 'fc' ~ '%02x' | format(node_idx * 32) ~ '::/19' -%}
{%- set advertise_routes = [fakeip_inet4_range, fakeip_inet6_range] + _rules_ip_cidrs -%}
{%- set peer_custom_rules = deterministic_peers | map('extract', hostvars) | map(attribute='dns.local_domains', default=[]) | flatten -%}

{# --- Route exclusion inputs for local TUN inbounds --- #}
{%- set peer_host_routes = deterministic_peers | map('extract', hostvars) | map(attribute='ansible_host') | map('regex_replace', '$', '/32') | list -%}
{%- set local_host_route = [ansible_host ~ '/32'] -%}
{%- set tun_route_excludes = local_host_route + peer_host_routes -%}

{# --- Protocol-specific helper values (WG/VLESS) --- #}
{%- set _wg_net = wg.subnet.split('/') if wg is defined and wg.subnet is defined else [] -%}
{%- set _wg_base = _wg_net[0].rsplit('.', 1)[0] if _wg_net else '' -%}
{%- set _wg_prefix = _wg_net[1] if _wg_net else '24' -%}
{%- set _wg_clients = wireguard_clients_with_keys if wireguard_clients_with_keys is defined else [] -%}
{%- set _has_wg_endpoints = wg_private_key is defined and (_wg_clients | length) > 0 -%}
{%- set _vless_clients = vless_clients_with_credentials if vless_clients_with_credentials is defined else [] -%}
{
  "dns": {
    "final": "upstream-local",
    "independent_cache": true,
    "rules": [
      {
        "query_type": ["HTTPS"],
        "action": "reject",
        "reject_code": 3
      },
      {
        "rule_set": ["route-rules"],
        "query_type": ["A", "AAAA"],
        "server": "fakeip"
      },
      {
        "rule_set": ["route-rules"],
        "server": "upstream-local"
      }{% if peer_custom_rules %},
      {
        "domain_suffix": {{ peer_custom_rules | to_json }},
        "query_type": ["A", "AAAA"],
        "server": "fakeip"
      },
      {
        "domain_suffix": {{ peer_custom_rules | to_json }},
        "server": "upstream-local"
      }{% endif %}
    ],
    "servers": [
{% for peer in deterministic_peers %}
      {
        "type": "udp",
        "tag": "upstream-tunnel-{{ peer }}",
        "server": "{{ hostvars[peer]['dns']['local_server']}}",
        "detour": "peer-{{ peer }}"
      },
{% endfor %}
      {
        "type": "udp",
        "tag": "upstream-local",
        "server": "{{ dns.local_server }}"
      },
      {
        "type": "fakeip",
        "tag": "fakeip",
        "inet4_range": "{{ fakeip_inet4_range }}",
        "inet6_range": "{{ fakeip_inet6_range }}"
      }
    ]
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "store_fakeip": true,
      "path": "/var/lib/sing-box/cache.db"
    }
  },
  "endpoints": [
{% for peer in deterministic_peers %}
    {
      "advertise_routes": {{ advertise_routes | to_json }},
{% if vault_tailscale_auth_key is defined and vault_tailscale_auth_key %}
      "auth_key": "{{ vault_tailscale_auth_key }}",
{% endif %}
      "ephemeral": false,
      "hostname": "{{ tailscale.hostname }}-{{ peer }}",
      "state_directory": "/var/lib/sing-box/tailscale-{{ peer }}",
      "tag": "ts-ep-{{ peer }}",
      "type": "tailscale"
    }{% if not loop.last or _has_wg_endpoints %},{% endif %}
{% endfor %}
{% if _has_wg_endpoints %}{% for peer in deterministic_peers %}
{%- set peer_clients = _wg_clients | selectattr('selected_peer', 'equalto', peer) | list -%}
    {
      "type": "wireguard",
      "tag": "wg-ep-{{ peer }}",
      "address": ["{{ _wg_base }}.1/{{ _wg_prefix }}"],
      "listen_port": {{ (wg.port | int) + loop.index0 }},
      "private_key": "{{ wg_private_key }}",
      "peers": [
{% for client in peer_clients %}
        {
          "public_key": "{{ client.public_key }}",
          "allowed_ips": ["{{ client.ip }}/32"]
        }{% if not loop.last %},{% endif %}
{% endfor %}
      ]
    }{% if not loop.last %},{% endif %}
{% endfor %}{% endif %}
  ],
  "inbounds": [
{% for peer in deterministic_peers %}
    {
      "type": "tun",
      "tag": "awg-in-{{ peer }}",
      "interface_name": "sb-awg-in-{{ peer }}",
      "address": ["172.19.{{ 10 + loop.index0 }}.1/30"],
      "include_interface": ["awg-in-{{ peer }}"],
      "route_exclude_address": {{ tun_route_excludes | unique | list | to_json }},
      "auto_route": {{ (loop.index0 == 0) | to_json }},
      "strict_route": {{ (loop.index0 == 0) | to_json }},
      "mtu": 9000
    }{% if not loop.last or (_vless_clients | length) > 0 %},{% endif %}
{% endfor %}
{% if (_vless_clients | length) > 0 %}
    {
      "type": "hysteria2",
      "tag": "tunnel-in",
      "listen": "0.0.0.0",
      "listen_port": {{ hysteria2.port }},
      "users": [
        { "password": "{{ vault_hysteria2_password }}" }
      ],
      "tls": {
        "enabled": true,
        "certificate_path": "/etc/sing-box/tls/cert.pem",
        "key_path": "/etc/sing-box/tls/key.pem"
      }
    },
    {
      "type": "vless",
      "tag": "vless-in",
      "listen": "0.0.0.0",
      "listen_port": {{ vless.port }},
      "users": [
{% for client in _vless_clients %}
        {
          "name": "{{ client.auth_user }}",
          "uuid": "{{ client.uuid }}",
          "flow": "xtls-rprx-vision"
        }{% if not loop.last %},{% endif %}
{% endfor %}
      ],
      "tls": {
        "enabled": true,
        "min_version": "1.3",
        "reality": {
          "enabled": true,
          "handshake": {
            "server": "{{ vless.domain }}",
            "server_port": {{ vless.port }}
          },
          "private_key": "{{ vless.private_key }}",
          "short_id": ["{{ vless.short_id }}"],
          "max_time_difference": "{{ vless.max_time_difference }}"
        }
      }
    }
{% else %}
    {
      "type": "hysteria2",
      "tag": "tunnel-in",
      "listen": "0.0.0.0",
      "listen_port": {{ hysteria2.port }},
      "users": [
        { "password": "{{ vault_hysteria2_password }}" }
      ],
      "tls": {
        "enabled": true,
        "certificate_path": "/etc/sing-box/tls/cert.pem",
        "key_path": "/etc/sing-box/tls/key.pem"
      }
    }
{% endif %}
  ],
  "log": {
    "level": "{{ log.level }}"
  },
  "outbounds": [
    {
      "tag": "direct",
      "type": "direct"
    },
{% for peer in deterministic_peers %}
    {
      "tag": "peer-{{ peer }}",
      "type": "hysteria2",
      "server": "{{ hostvars[peer]['ansible_host'] }}",
      "server_port": {{ hysteria2.port }},
      "password": "{{ vault_hysteria2_password }}",
      "tls": {
        "enabled": true,
        "insecure": true
      }
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ],
  "route": {
    "auto_detect_interface": true,
    "rule_set": [
      {
        "tag": "route-rules",
        "type": "remote",
        "format": "source",
        "url": "{{ rule_set.base_url }}/{{ 'restricted' if restricted else 'unrestricted' }}.json",
        "update_interval": "5m"
      }
    ],
    "default_domain_resolver": {
      "server": "upstream-local"
    },
    "final": "direct",
    "rules": [
      {
        "inbound": ["tunnel-in"],
        "port": [53],
        "action": "route",
        "outbound": "direct"
      },
      {
        "port": [53],
        "action": "hijack-dns"
      }{% for peer in deterministic_peers %},
{%- set peer_vless_auth_users = _vless_clients | selectattr('selected_peer', 'equalto', peer) | map(attribute='auth_user') | list -%}
      {
        "inbound": ["ts-ep-{{ peer }}", "awg-in-{{ peer }}", "wg-ep-{{ peer }}"],
        "action": "route",
        "outbound": "peer-{{ peer }}"
      }{% if peer_vless_auth_users %},
      {
        "auth_user": {{ peer_vless_auth_users | to_json }},
        "action": "route",
        "outbound": "peer-{{ peer }}"
      }{% endif %}{% endfor %}
    ]
  }
}
