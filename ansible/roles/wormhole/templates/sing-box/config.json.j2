{%- set node_idx = groups['all'].index(inventory_hostname) -%}
{%- set fakeip_inet4_range = '198.' ~ (18 + node_idx) ~ '.0.0/16' -%}
{%- set fakeip_inet6_range = 'fc' ~ '%02x' | format(node_idx * 32) ~ '::/19' -%}
{%- set _rules_file = lookup('file', playbook_dir ~ '/../rules/' ~ ('restricted' if restricted else 'unrestricted') ~ '.json') | from_json -%}
{%- set _rules_ip_cidrs = _rules_file.rules | map(attribute='ip_cidr', default=[]) | flatten -%}
{%- set advertise_routes = [fakeip_inet4_range, fakeip_inet6_range] + _rules_ip_cidrs -%}
{%- set tunnel_dns = hostvars[peers[0]]['dns_local_server'] -%}
{%- set peer_domain_suffixes = peers | map('extract', hostvars) | map(attribute='local_domains', default=[]) | flatten -%}
{
  "dns": {
    "final": "upstream-local",
    "independent_cache": true,
    "rules": [
      {
        "query_type": ["HTTPS"],
        "action": "reject",
        "reject_code": 3
      },
      {
        "rule_set": ["route-rules"],
        "query_type": ["A", "AAAA"],
        "server": "fakeip"
      },
      {
        "rule_set": ["route-rules"],
        "server": "upstream-tunnel"
      }{% if peer_domain_suffixes %},
      {
        "domain_suffix": {{ peer_domain_suffixes | to_json }},
        "query_type": ["A", "AAAA"],
        "server": "fakeip"
      },
      {
        "domain_suffix": {{ peer_domain_suffixes | to_json }},
        "server": "upstream-tunnel"
      }{% endif %}
    ],
    "servers": [
      {
        "type": "udp",
        "tag": "upstream-tunnel",
        "server": "{{ tunnel_dns }}"{% if restricted %},
        "detour": "tunnel"{% endif %}
      },
      {
        "type": "udp",
        "tag": "upstream-local",
        "server": "{{ dns_local_server }}"
      },
      {
        "type": "fakeip",
        "tag": "fakeip",
        "inet4_range": "{{ fakeip_inet4_range }}",
        "inet6_range": "{{ fakeip_inet6_range }}"
      }
    ]
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "store_fakeip": true,
      "path": "/var/lib/sing-box/cache.db"
    }
  },
  "endpoints": [
    {
      "advertise_routes": {{ advertise_routes | to_json }},
{% if vault_tailscale_auth_key | default('') %}
      "auth_key": "{{ vault_tailscale_auth_key }}",
{% endif %}
      "ephemeral": false,
      "hostname": "{{ tailscale_hostname }}",
      "state_directory": "/var/lib/sing-box/tailscale",
      "tag": "ts-ep",
      "type": "tailscale"
    }
  ],
  "inbounds": [],
  "log": {
    "level": "{{ log_level }}"
  },
  "outbounds": [
    {
      "tag": "direct",
      "type": "direct"
    }{% if restricted %},
    {
      "tag": "tunnel",
      "type": "direct",
      "routing_mark": 51820
    }{% endif %}
  ],
  "route": {
    "rule_set": [
      {
        "tag": "route-rules",
        "type": "remote",
        "format": "source",
        "url": "{{ rule_set_base_url }}/{{ 'restricted' if restricted else 'unrestricted' }}.json",
        "update_interval": "5m"
      }
    ],
    "default_domain_resolver": {
      "server": "upstream-local"
    },
    "final": "direct",
    "rules": [
      {
        "port": [53],
        "action": "hijack-dns"
      },
      {
        "rule_set": ["route-rules"],
        "action": "route",
        "outbound": "{{ 'tunnel' if restricted else 'direct' }}"
      }{% if peer_domain_suffixes %},
      {
        "domain_suffix": {{ peer_domain_suffixes | to_json }},
        "action": "route",
        "outbound": "{{ 'tunnel' if restricted else 'direct' }}"
      }{% endif %}
    ]
  }
}
