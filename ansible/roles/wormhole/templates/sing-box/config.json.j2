{%- set node_idx = groups['all'].index(inventory_hostname) -%}
{%- set fakeip_inet4_range = '198.' ~ (18 + node_idx) ~ '.0.0/16' -%}
{%- set fakeip_inet6_range = 'fc' ~ '%02x' | format(node_idx * 32) ~ '::/19' -%}
{%- set _rules_file = lookup('file', playbook_dir ~ '/../rules/' ~ ('restricted' if restricted else 'unrestricted') ~ '.json') | from_json -%}
{%- set _rules_ip_cidrs = _rules_file.rules | map(attribute='ip_cidr', default=[]) | flatten -%}
{%- set advertise_routes = [fakeip_inet4_range, fakeip_inet6_range] + _rules_ip_cidrs -%}
{%- set peer_host_routes = peers | map('extract', hostvars) | map(attribute='ansible_host') | map('regex_replace', '$', '/32') | list -%}
{%- set local_host_route = [ansible_host ~ '/32'] -%}
{%- set tun_route_excludes = local_host_route + peer_host_routes -%}
{%- set tunnel_dns = hostvars[peers[0]]['dns']['local_server'] -%}
{%- set peer_domain_suffixes = peers | map('extract', hostvars) | map(attribute='dns.local_domains', default=[]) | flatten -%}
{
  "dns": {
    "final": "upstream-local",
    "independent_cache": true,
    "rules": [
      {
        "query_type": ["HTTPS"],
        "action": "reject",
        "reject_code": 3
      },
      {
        "rule_set": ["route-rules"],
        "query_type": ["A", "AAAA"],
        "server": "fakeip"
      },
      {
        "rule_set": ["route-rules"],
        "server": "upstream-local"
      }{% if peer_domain_suffixes %},
      {
        "domain_suffix": {{ peer_domain_suffixes | to_json }},
        "query_type": ["A", "AAAA"],
        "server": "fakeip"
      },
      {
        "domain_suffix": {{ peer_domain_suffixes | to_json }},
        "server": "upstream-local"
      }{% endif %}
    ],
    "servers": [
      {
        "type": "udp",
        "tag": "upstream-tunnel",
        "server": "{{ tunnel_dns }}",
        "detour": "tunnel"
      },
      {
        "type": "udp",
        "tag": "upstream-local",
        "server": "{{ dns.local_server }}"
      },
      {
        "type": "fakeip",
        "tag": "fakeip",
        "inet4_range": "{{ fakeip_inet4_range }}",
        "inet6_range": "{{ fakeip_inet6_range }}"
      }
    ]
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "store_fakeip": true,
      "path": "/var/lib/sing-box/cache.db"
    }
  },
  "endpoints": [
    {
      "advertise_routes": {{ advertise_routes | to_json }},
{% if vault_tailscale_auth_key | default('') %}
      "auth_key": "{{ vault_tailscale_auth_key }}",
{% endif %}
      "ephemeral": false,
      "hostname": "{{ tailscale.hostname }}",
      "state_directory": "/var/lib/sing-box/tailscale",
      "tag": "ts-ep",
      "type": "tailscale"
    }
  ],
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "sb-tun",
      "address": ["172.19.0.1/30"],
      "include_interface": ["awg-in"],
      "route_exclude_address": {{ tun_route_excludes | unique | list | to_json }},
      "auto_route": true,
      "strict_route": true,
      "mtu": 9000
    },
    {
      "type": "hysteria2",
      "tag": "tunnel-in",
      "listen": "0.0.0.0",
      "listen_port": {{ hysteria2.port }},
      "users": [
        { "password": "{{ vault_hysteria2_password }}" }
      ],
      "tls": {
        "enabled": true,
        "certificate_path": "/etc/sing-box/tls/cert.pem",
        "key_path": "/etc/sing-box/tls/key.pem"
      }
    }
  ],
  "log": {
    "level": "{{ log.level }}"
  },
  "outbounds": [
    {
      "tag": "direct",
      "type": "direct"
    },
{% for p in peers %}
    {
      "tag": "peer-{{ p }}",
      "type": "hysteria2",
      "server": "{{ hostvars[p]['ansible_host'] }}",
      "server_port": {{ hysteria2.port }},
      "password": "{{ vault_hysteria2_password }}",
      "tls": {
        "enabled": true,
        "insecure": true
      }
    },
{% endfor %}
    {
      "tag": "tunnel",
      "type": "selector",
      "outbounds": [{% for p in peers %}"peer-{{ p }}"{% if not loop.last %}, {% endif %}{% endfor %}]
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "rule_set": [
      {
        "tag": "route-rules",
        "type": "remote",
        "format": "source",
        "url": "{{ rule_set.base_url }}/{{ 'restricted' if restricted else 'unrestricted' }}.json",
        "update_interval": "5m"
      }
    ],
    "default_domain_resolver": {
      "server": "upstream-local"
    },
    "final": "direct",
    "rules": [
      {
        "inbound": ["tunnel-in"],
        "port": [53],
        "action": "route",
        "outbound": "direct"
      },
      {
        "port": [53],
        "action": "hijack-dns"
      },
      {
        "rule_set": ["route-rules"],
        "action": "route",
        "outbound": "tunnel"
      }{% if peer_domain_suffixes %},
      {
        "domain_suffix": {{ peer_domain_suffixes | to_json }},
        "action": "route",
        "outbound": "tunnel"
      }{% endif %}
    ]
  }
}
