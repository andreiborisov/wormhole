{%- set stable_peers = peers | default([]) | unique | sort -%}
{%- set awg_peer_subnets = stable_peers | map('extract', hostvars) | map(attribute='awg.subnet', default=awg.subnet) | unique | list -%}
add table ip wormhole
flush table ip wormhole

table ip wormhole {

  # FILTER

  chain input {
    type filter hook input priority filter; policy accept;
    ct state invalid drop
    ct state established,related accept
    iif lo accept
    iifname "awg-in-*" accept
  }

  chain forward {
    type filter hook forward priority filter; policy accept;
    ct state invalid drop
    ct state established,related accept
    # Allow non-TPROXY'd VPN traffic (ICMP, etc.) to be forwarded
    iifname "awg-in-*" ip saddr { {{ awg_peer_subnets | join(', ') }} } accept
  }

  # NAT

  chain postrouting {
    type nat hook postrouting priority srcnat; policy accept;
    # Masquerade non-TPROXY'd VPN traffic (ICMP, etc.)
    ip saddr { {{ awg_peer_subnets | join(', ') }} }{% for p in stable_peers %} oifname != "awg-in-{{ p }}"{% endfor %} masquerade
  }
}
