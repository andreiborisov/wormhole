add table ip wormhole
flush table ip wormhole

define VPN_INTERFACE = "awg-in"
define VPN_SUBNET   = {{ awg.subnet }}

table ip wormhole {

  # FILTER

  chain input {
    type filter hook input priority filter; policy accept;
    ct state invalid drop
    ct state established,related accept
    iif lo accept
    iifname $VPN_INTERFACE accept
  }

  chain forward {
    type filter hook forward priority filter; policy accept;
    ct state invalid drop
    ct state established,related accept
    # Allow non-TPROXY'd VPN traffic (ICMP, etc.) to be forwarded
    iifname $VPN_INTERFACE ip saddr $VPN_SUBNET accept
  }

  # NAT

  chain postrouting {
    type nat hook postrouting priority srcnat; policy accept;
    # Masquerade non-TPROXY'd VPN traffic (ICMP, etc.)
    ip saddr $VPN_SUBNET oifname != $VPN_INTERFACE masquerade
  }
}

