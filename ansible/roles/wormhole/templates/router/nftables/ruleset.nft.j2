flush ruleset

define VPN_INTERFACE = "awg-in"
define VPN_SUBNET   = {{ awg.subnet }}
define TPROXY_PORT  = {{ tproxy.port }}
define TPROXY_MARK = 0x100

# FILTER

table ip filter {

  chain input {
    type filter hook input priority filter; policy accept;
    ct state invalid drop
    ct state established,related accept
    iif lo accept
    iif $VPN_INTERFACE accept
  }

  chain forward {
    type filter hook forward priority filter; policy accept;
    ct state invalid drop
    ct state established,related accept
    # Allow non-TPROXY'd VPN traffic (ICMP, etc.) to be forwarded
    iif $VPN_INTERFACE ip saddr $VPN_SUBNET accept
  }

  chain output {
    type filter hook output priority filter; policy accept;
  }
}

# NAT

table ip nat {

  chain postrouting {
    type nat hook postrouting priority srcnat; policy accept;
    # Masquerade non-TPROXY'd VPN traffic (ICMP, etc.)
    ip saddr $VPN_SUBNET oifname != $VPN_INTERFACE masquerade
  }
}

# TPROXY

table ip mangle {

  chain prerouting {
    type filter hook prerouting priority mangle; policy accept;

    iif $VPN_INTERFACE socket transparent 1 meta mark set $TPROXY_MARK accept

    # Intercept traffic from VPN clients → sing-box transparent proxy
    iif $VPN_INTERFACE meta l4proto tcp tproxy to :$TPROXY_PORT meta mark set $TPROXY_MARK
    iif $VPN_INTERFACE meta l4proto udp tproxy to :$TPROXY_PORT meta mark set $TPROXY_MARK
  }
}
