#!/bin/bash

echo "Loading modules"

modprobe tcp_hybla

echo "Starting AmneziaWG"

# kill daemons in case of restart
awg-quick down /opt/amnezia/awg/awg-in.conf

# start daemons if configured
if [ -f /opt/amnezia/awg/awg-in.conf ]; then (awg-quick up /opt/amnezia/awg/awg-in.conf); fi

# Allow traffic on the TUN interface.
iptables -A INPUT -i awg-in -j ACCEPT
iptables -A FORWARD -i awg-in -j ACCEPT
iptables -A OUTPUT -o awg-in -j ACCEPT

# Allow forwarding traffic only from the VPN.
iptables -A FORWARD -i awg-in -o eth0 -s {{ awg_subnet }} -j ACCEPT
iptables -A FORWARD -i awg-in -o eth1 -s {{ awg_subnet }} -j ACCEPT

iptables -A FORWARD -m state --state ESTABLISHED,RELATED -j ACCEPT

iptables -t nat -A POSTROUTING -s {{ awg_subnet }} -o eth0 -j MASQUERADE
iptables -t nat -A POSTROUTING -s {{ awg_subnet }} -o eth1 -j MASQUERADE

tail -f /dev/null
