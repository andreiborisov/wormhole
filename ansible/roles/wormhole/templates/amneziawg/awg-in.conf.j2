{%- set _net = awg.subnet.split('/') -%}
{%- set _base = _net[0].rsplit('.', 1)[0] -%}
[Interface]
Address    = {{ _base }}.1/{{ _net[1] }}
ListenPort = {{ awg.port }}
PrivateKey = {{ awg_private_key }}
{% if awg.jc is defined %}
Jc   = {{ awg.jc }}
{% endif %}
{% if awg.jmin is defined %}
Jmin = {{ awg.jmin }}
{% endif %}
{% if awg.jmax is defined %}
Jmax = {{ awg.jmax }}
{% endif %}
{% if awg.s1 is defined %}
S1   = {{ awg.s1 }}
{% endif %}
{% if awg.s2 is defined %}
S2   = {{ awg.s2 }}
{% endif %}
{% if awg.s3 is defined %}
S3   = {{ awg.s3 }}
{% endif %}
{% if awg.s4 is defined %}
S4   = {{ awg.s4 }}
{% endif %}
{% if awg.h1 is defined %}
H1   = {{ awg.h1 }}
{% endif %}
{% if awg.h2 is defined %}
H2   = {{ awg.h2 }}
{% endif %}
{% if awg.h3 is defined %}
H3   = {{ awg.h3 }}
{% endif %}
{% if awg.h4 is defined %}
H4   = {{ awg.h4 }}
{% endif %}
{% if awg.i1 is defined %}
I1   = {{ awg.i1 }}
{% endif %}
{% if awg.i2 is defined %}
I2   = {{ awg.i2 }}
{% endif %}
{% if awg.i3 is defined %}
I3   = {{ awg.i3 }}
{% endif %}
{% if awg.i4 is defined %}
I4   = {{ awg.i4 }}
{% endif %}
{% if awg.i5 is defined %}
I5   = {{ awg.i5 }}
{% endif %}
{% for peer in awg_clients_with_keys | default([]) %}

[Peer]
# {{ peer.name }}
PublicKey  = {{ peer.public_key }}
AllowedIPs = {{ peer.ip }}/32
{% endfor %}
