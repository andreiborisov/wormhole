{%- set node_idx = groups['all'].index(inventory_hostname) -%}
{%- set fakeip_inet4_range = '198.' ~ (18 + node_idx) ~ '.0.0/16' -%}
{%- set fakeip_inet6_range = 'fc' ~ '%02x' | format(node_idx * 32) ~ '::/19' -%}
{%- set _rules_file = lookup('file', playbook_dir ~ '/../rules/' ~ ('restricted' if restricted else 'unrestricted') ~ '.json') | from_json -%}
{%- set _rules_ip_cidrs = _rules_file.rules | map(attribute='ip_cidr', default=[]) | flatten -%}
{%- set _apply_rules = (peer.mode | default('split')) == 'split' -%}
{%- set allowed_ips = ([wg.subnet, fakeip_inet4_range, fakeip_inet6_range] + _rules_ip_cidrs) if _apply_rules else ['0.0.0.0/0', '::/0'] -%}
{%- set _wg_base = wg.subnet.split('/')[0].rsplit('.', 1)[0] -%}
[Interface]
# profile = {{ peer.profile_name | default(peer.name) }}, entry = {{ inventory_hostname }}, exit = {{ peer.selected_peer | default('default') }}
Address    = {{ peer.ip }}/32
PrivateKey = {{ peer_private_key }}
DNS        = {{ _wg_base }}.53

[Peer]
PublicKey           = {{ wg_public_key }}
Endpoint            = {{ ansible_host }}:{{ peer.listen_port | default(wg.port | default(51821)) }}
AllowedIPs          = {{ allowed_ips | join(', ') }}
PersistentKeepalive = 25
