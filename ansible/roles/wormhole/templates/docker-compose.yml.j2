services:

  router:
    build:
      context: ./router
    image: router:latest
    container_name: router
    networks:
      - wormhole
    ports:
      - "{{ awg.port }}:{{ awg.port }}/udp"
      - "{{ hysteria2.port }}:{{ hysteria2.port }}/udp"
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    volumes:
      - /lib/modules:/lib/modules:ro
      - ./router/nftables/ruleset.nft:/etc/nftables/ruleset.nft:ro
      - ./router/docker-entrypoint.fish:/docker-entrypoint.fish:ro
    command: ["awg-in"]
    restart: unless-stopped

  amneziawg:
    build:
      context: ./amneziawg
    image: amneziawg:{{ image_tags.amneziawg }}
    container_name: amneziawg
    network_mode: "service:router"
    depends_on:
      - router
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    ulimits:
      nofile:
        soft: 51200
        hard: 51200
    sysctls:
      # Forwarding
      net.ipv4.ip_forward: 1
      net.ipv4.conf.all.src_valid_mark: 1
      # Networking
      net.core.somaxconn: 4096
      # TCP tuning
      net.ipv4.tcp_syncookies: 1
      net.ipv4.tcp_tw_reuse: 1
      net.ipv4.tcp_fin_timeout: 30
      net.ipv4.tcp_keepalive_time: 1200
      net.ipv4.ip_local_port_range: "10000 65000"
      net.ipv4.tcp_max_syn_backlog: 8192
      net.ipv4.tcp_max_tw_buckets: 5000
      net.ipv4.tcp_fastopen: 3
      net.ipv4.tcp_rmem: "4096 87380 67108864"
      net.ipv4.tcp_wmem: "4096 65536 67108864"
      net.ipv4.tcp_mtu_probing: 1
      net.ipv4.tcp_slow_start_after_idle: 0
      net.ipv4.tcp_no_metrics_save: 1
    devices:
      - /dev/net/tun:/dev/net/tun
    volumes:
      - /lib/modules:/lib/modules:ro
      - ./amneziawg/awg-in.conf:/opt/amnezia/awg/awg-in.conf:ro
      - ./amneziawg/docker-entrypoint.fish:/opt/amnezia/docker-entrypoint.fish:ro
    healthcheck:
      test: ["CMD", "awg", "show", "awg-in"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 15s
    restart: unless-stopped

  sing-box:
    image: ghcr.io/sagernet/sing-box:{{ image_tags.sing_box }}
    container_name: sing-box
    network_mode: "service:router"
    depends_on:
      amneziawg:
        condition: service_healthy
      router:
        condition: service_started
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    command:
      - -D
      - /var/lib/sing-box
      - -C
      - /etc/sing-box/
      - run
    volumes:
      - ./sing-box/config.json:/etc/sing-box/config.json:ro
      - ./sing-box/data:/var/lib/sing-box
      - ./sing-box/tls:/etc/sing-box/tls:ro
    restart: unless-stopped

networks:
  wormhole:
    driver: bridge
