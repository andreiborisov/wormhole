services:

  router:
    build:
      context: ./router
    image: router:latest
    container_name: router
    network_mode: host
    cap_add:
      - NET_ADMIN
    volumes:
      - ./router/nftables/ruleset.nft:/etc/nftables/ruleset.nft:ro
      - ./router/docker-entrypoint.fish:/docker-entrypoint.fish:ro
    restart: "no"

  amneziawg:
    build:
      context: ./amneziawg
    image: amneziawg:{{ image_tags.amneziawg }}
    container_name: amneziawg
    network_mode: host
    depends_on:
      router:
        condition: service_completed_successfully
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    ulimits:
      nofile:
        soft: 51200
        hard: 51200
    devices:
      - /dev/net/tun:/dev/net/tun
    volumes:
      - /lib/modules:/lib/modules:ro
      - ./amneziawg/awg-in.conf:/opt/amnezia/awg/awg-in.conf:ro
      - ./amneziawg/docker-entrypoint.fish:/opt/amnezia/docker-entrypoint.fish:ro
    healthcheck:
      test: ["CMD", "awg", "show", "awg-in"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 15s
    restart: unless-stopped

  sing-box:
    image: ghcr.io/sagernet/sing-box:{{ image_tags.sing_box }}
    container_name: sing-box
    network_mode: host
    depends_on:
      router:
        condition: service_completed_successfully
      amneziawg:
        condition: service_healthy
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    command:
      - -D
      - /var/lib/sing-box
      - -C
      - /etc/sing-box/
      - run
    volumes:
      - ./sing-box/config.json:/etc/sing-box/config.json:ro
      - ./sing-box/data:/var/lib/sing-box
      - ./sing-box/tls:/etc/sing-box/tls:ro
    restart: unless-stopped
