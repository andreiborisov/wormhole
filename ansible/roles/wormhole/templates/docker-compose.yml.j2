services:

  amneziawg:
    build:
      context: ./amneziawg/build
    image: amneziawg:latest
    container_name: amneziawg
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    networks:
      - wormhole
    ports:
      - "{{ awg_port }}:{{ awg_port }}/udp"
    ulimits:
      nofile:
        soft: 51200
        hard: 51200
    sysctls:
      # Forwarding
      net.ipv4.ip_forward: 1
      net.ipv4.conf.all.src_valid_mark: 1
      # Core networking
      net.core.rmem_max: 67108864
      net.core.wmem_max: 67108864
      net.core.netdev_max_backlog: 250000
      net.core.somaxconn: 4096
      # TCP tuning
      net.ipv4.tcp_syncookies: 1
      net.ipv4.tcp_tw_reuse: 1
      net.ipv4.tcp_fin_timeout: 30
      net.ipv4.tcp_keepalive_time: 1200
      net.ipv4.ip_local_port_range: "10000 65000"
      net.ipv4.tcp_max_syn_backlog: 8192
      net.ipv4.tcp_max_tw_buckets: 5000
      net.ipv4.tcp_fastopen: 3
      net.ipv4.tcp_mem: "25600 51200 102400"
      net.ipv4.tcp_rmem: "4096 87380 67108864"
      net.ipv4.tcp_wmem: "4096 65536 67108864"
      net.ipv4.tcp_mtu_probing: 1
      net.ipv4.tcp_congestion_control: hybla
    devices:
      - /dev/net/tun:/dev/net/tun
    volumes:
      - /lib/modules:/lib/modules:ro
      - ./amneziawg/awg-in.conf:/opt/amnezia/awg/awg-in.conf:ro
      - ./amneziawg/start.sh:/opt/amnezia/start.sh:ro
    healthcheck:
      test: ["CMD", "awg", "show", "awg-in"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 15s
    restart: unless-stopped

  sing-box:
    image: ghcr.io/sagernet/sing-box:v1.13.8
    container_name: sing-box
    depends_on:
      amneziawg:
        condition: service_healthy
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    network_mode: "service:amneziawg"
    command:
      - -D
      - /var/lib/sing-box
      - -C
      - /etc/sing-box/
      - run
    volumes:
      - ./sing-box/config.json:/etc/sing-box/config.json:ro
      - ./sing-box/data:/var/lib/sing-box
    restart: unless-stopped

networks:
  wormhole:
    driver: bridge
