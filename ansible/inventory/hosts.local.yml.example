# Copy this file to hosts.local.yml (gitignored) and fill in real values.
#
#   cp hosts.local.yml.example hosts.local.yml

all:
  vars:
    rule_set_base_url: "https://raw.githubusercontent.com/YOUR_ORG/YOUR_REPO/main/rules"
    ansible_ssh_private_key_file: ~/.ssh/id_ed25519
  hosts:
    wormhole-ru:
      ansible_host: YOUR_WORMHOLE_RU_IP
      ansible_user: root
      tailscale_hostname: "wormhole-ru"
      peers:
        - "wormhole-fi"
      restricted: true
      dns_local_server: "77.88.8.8"
    wormhole-fi:
      ansible_host: YOUR_WORMHOLE_FI_IP
      ansible_user: root
      tailscale_hostname: "wormhole-fi"
      peers:
        - "wormhole-ru"
      restricted: false
      dns_local_server: "1.1.1.1"
